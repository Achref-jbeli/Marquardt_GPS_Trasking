@{
    Layout = null;
    ViewData["Title"] = "Approbations en attente";
    var requests = Model as List<GpsAdminServer.Models.TravelRequest>;
    var user = ViewBag.User as GpsAdminServer.Models.ApplicationUser;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Approbations - GPS Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f5f5f5;
        }

        .navbar {
            background: #2c3e50;
            color: white;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }

        .logo {
            font-size: 20px;
            font-weight: bold;
        }

            .logo span {
                color: #3498db;
            }

        .nav-links a {
            color: white;
            text-decoration: none;
            margin-left: 20px;
            padding: 8px 12px;
            border-radius: 5px;
            transition: background 0.3s;
        }

            .nav-links a:hover {
                background: #34495e;
            }

            .nav-links a.active {
                background: #3498db;
            }

        .container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
        }

        .header {
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }

            .header h2 {
                color: #2c3e50;
            }

        .badge-count {
            background: #e74c3c;
            color: white;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 14px;
            margin-left: 10px;
        }

        .alert {
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .alert-success {
            background: #e8f8f5;
            color: #27ae60;
            border: 1px solid #27ae60;
        }

        .alert-error {
            background: #fdecea;
            color: #e74c3c;
            border: 1px solid #e74c3c;
        }

        .request-card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 15px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .request-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 15px rgba(0,0,0,0.15);
            }

        .request-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px solid #eee;
            flex-wrap: wrap;
        }

        .employee-name {
            font-weight: bold;
            color: #2c3e50;
            font-size: 18px;
        }

            .employee-name i {
                margin-right: 8px;
                color: #3498db;
            }

        .request-date {
            color: #666;
            font-size: 13px;
        }

        .request-details {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 15px;
        }

        .detail-item {
            color: #555;
        }

        .detail-label {
            font-weight: bold;
            margin-right: 5px;
            color: #2c3e50;
        }

        .request-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        .btn-approve {
            background: #27ae60;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            transition: background 0.3s;
        }

            .btn-approve:hover {
                background: #219a52;
            }

        .btn-reject {
            background: #e74c3c;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            transition: background 0.3s;
        }

            .btn-reject:hover {
                background: #c0392b;
            }

        .btn-view {
            background: #3498db;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.3s;
        }

            .btn-view:hover {
                background: #2980b9;
            }

        .comment-input {
            flex: 1;
            min-width: 200px;
            padding: 8px 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 14px;
        }

            .comment-input:focus {
                outline: none;
                border-color: #3498db;
            }

        .empty-state {
            text-align: center;
            padding: 60px;
            background: white;
            border-radius: 12px;
            color: #999;
        }

            .empty-state i {
                font-size: 60px;
                margin-bottom: 20px;
                color: #ccc;
            }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1000;
        }

        .modal-content {
            background: white;
            width: 450px;
            margin: 100px auto;
            padding: 25px;
            border-radius: 12px;
            animation: fadeIn 0.3s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .modal-content h3 {
            margin-bottom: 15px;
            color: #2c3e50;
        }

        .modal-content textarea {
            width: 100%;
            padding: 10px;
            margin: 15px 0;
            border: 1px solid #ddd;
            border-radius: 6px;
            resize: vertical;
            font-family: inherit;
        }

        .close {
            float: right;
            cursor: pointer;
            font-size: 24px;
            color: #999;
        }

            .close:hover {
                color: #e74c3c;
            }

        .modal-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
        }

        .info-banner {
            background: #e8f4f8;
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .info-banner i {
                color: #3498db;
                font-size: 20px;
            }

            .info-banner span {
                color: #2c3e50;
            }

        @@media (max-width: 768px) {
            .request-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }

            .request-details {
                grid-template-columns: 1fr;
            }

            .request-actions {
                flex-direction: column;
            }

            .comment-input {
                width: 100%;
            }

            .nav-links a {
                margin-left: 10px;
                font-size: 12px;
            }
        }
    </style>
</head>
<body>
    <div class="navbar">
        <div class="logo"><span>🚗</span> GPS Tracking Admin</div>
        <div class="nav-links">
            <a href="/Request/Dashboard">Dashboard</a>
            <a href="/Request/MyRequests">Mes demandes</a>
            @if (user?.Role == "Admin")
            {
            <a href="/Request/PendingApprovals" class="active">📍 Toutes les demandes</a>
            }
            else
            {
            <a href="/Request/PendingApprovals" class="active">📋 Demandes des employés</a>
            }
            <a href="/Request/ApprovedByMe">Approuvées</a>
            <a href="/Account/Logout">Déconnexion</a>
        </div>
    </div>

    <div class="container">
        <div class="header">
            @if (user?.Role == "Admin")
            {
            <h2><i class="fas fa-globe"></i> Toutes les demandes en attente</h2>
            }
            else
            {
            <h2><i class="fas fa-users"></i> Demandes de mes employés</h2>
            }
            @if (requests != null && requests.Any())
            {
            <span class="badge-count">@requests.Count demande(s)</span>
            }
        </div>

        <div class="info-banner">
            <i class="fas fa-info-circle"></i>
            @if (user?.Role == "Admin")
            {
            <span>En tant qu'administrateur, vous pouvez approuver ou refuser toutes les demandes.</span>
            }
            else
            {
            <span>Vous approuvez les demandes des employés dont vous êtes le responsable.</span>
            }
        </div>

        @if (TempData["Success"] != null)
        {
        <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
        <div class="alert alert-error">@TempData["Error"]</div>
        }

        @if (requests != null && requests.Any())
        {
            foreach (var request in requests)
            {
        <div class="request-card" id="card-@request.Id">
            <div class="request-header">
                <div class="employee-name">
                    <i class="fas fa-user-circle"></i> @request.EmployeeName
                </div>
                <div class="request-date">
                    <i class="fas fa-calendar-alt"></i> Demandée le @request.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>

            <div class="request-details">
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-map-marker-alt"></i> Départ:</span>
                    @request.Departure
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-flag-checkered"></i> Destination:</span>
                    @request.Destination
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-calendar-day"></i> Date voyage:</span>
                    @request.TravelDate.ToString("dd/MM/yyyy")
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-clock"></i> Heure arrivée:</span>
                    @request.ArrivalTime.ToString("HH:mm")
                </div>
                <div class="detail-item">
                    <span class="detail-label"><i class="fas fa-comment"></i> Motif:</span>
                    @request.Purpose
                </div>
            </div>

            <div class="request-actions">
                <input type="text" id="comment_@request.Id" class="comment-input"
                       placeholder="Commentaire (optionnel)" />
                <button class="btn-approve" onclick="showApproveModal(@request.Id)">
                    <i class="fas fa-check-circle"></i> Approuver
                </button>
                <button class="btn-reject" onclick="showRejectModal(@request.Id)">
                    <i class="fas fa-times-circle"></i> Refuser
                </button>
                <button class="btn-view" onclick="viewRequest(@request.Id)">
                    <i class="fas fa-eye"></i> Voir détails
                </button>
            </div>
        </div>
            }
        }
        else
        {
        <div class="empty-state">
            <i class="fas fa-check-circle"></i>
            <h3>Aucune demande en attente</h3>
            <p>Toutes les demandes ont été traitées.</p>
        </div>
        }
    </div>

    <!-- Modal Approbation -->
    <div id="approveModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeApproveModal()">&times;</span>
            <h3><i class="fas fa-check-circle" style="color: #27ae60;"></i> Approuver la demande</h3>
            <p>Voulez-vous vraiment approuver cette demande ?</p>
            <textarea id="approveComments" placeholder="Commentaire (optionnel)"></textarea>
            <div class="modal-actions">
                <button class="btn-approve" onclick="confirmApprove()">Confirmer</button>
                <button class="btn-view" onclick="closeApproveModal()">Annuler</button>
            </div>
        </div>
    </div>

    <!-- Modal Refus -->
    <div id="rejectModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeRejectModal()">&times;</span>
            <h3><i class="fas fa-times-circle" style="color: #e74c3c;"></i> Refuser la demande</h3>
            <p>Veuillez indiquer la raison du refus :</p>
            <textarea id="rejectComments" placeholder="Raison du refus (obligatoire)"></textarea>
            <div class="modal-actions">
                <button class="btn-reject" onclick="confirmReject()">Confirmer le refus</button>
                <button class="btn-view" onclick="closeRejectModal()">Annuler</button>
            </div>
        </div>
    </div>

    <script>
        var currentRequestId = null;

        function showApproveModal(id) {
            currentRequestId = id;
            document.getElementById('approveModal').style.display = 'block';
        }

        function closeApproveModal() {
            document.getElementById('approveModal').style.display = 'none';
            document.getElementById('approveComments').value = '';
            currentRequestId = null;
        }

        function showRejectModal(id) {
            currentRequestId = id;
            document.getElementById('rejectModal').style.display = 'block';
        }

        function closeRejectModal() {
            document.getElementById('rejectModal').style.display = 'none';
            document.getElementById('rejectComments').value = '';
            currentRequestId = null;
        }

        function confirmApprove() {
            var comments = document.getElementById('approveComments').value;
            fetch(`/Request/ApproveRequest?id=${currentRequestId}&comments=${encodeURIComponent(comments)}`, {
                method: 'POST'
            }).then(() => location.reload());
        }

        function confirmReject() {
            var comments = document.getElementById('rejectComments').value;
            if (!comments) {
                alert('Veuillez indiquer une raison du refus');
                return;
            }
            fetch(`/Request/RejectRequest?id=${currentRequestId}&comments=${encodeURIComponent(comments)}`, {
                method: 'POST'
            }).then(() => location.reload());
        }

        function viewRequest(id) {
            window.location.href = `/Request/RequestDetails?id=${id}`;
        }

        // Fermer modals en cliquant en dehors
        window.onclick = function (event) {
            if (event.target == document.getElementById('approveModal')) {
                closeApproveModal();
            }
            if (event.target == document.getElementById('rejectModal')) {
                closeRejectModal();
            }
        }
    </script>
</body>
</html>