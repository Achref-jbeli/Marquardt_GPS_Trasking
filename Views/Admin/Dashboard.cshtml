@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
    var pendingRequests = ViewBag.PendingRequests ?? 0;
    var supervisorApprovedRequests = ViewBag.SupervisorApprovedRequests ?? 0;
    var completedRequests = ViewBag.CompletedRequests ?? 0;
    var activeVehicles = ViewBag.ActiveVehicles ?? 0;
    var totalDrivers = ViewBag.TotalDrivers ?? 0;
    var totalUsers = ViewBag.TotalUsers ?? 0;
    var latestRequests = ViewBag.LatestRequests as List<GpsAdminServer.Models.TravelRequest>;
}

<div class="page-header">
    <h2><i class="fas fa-chart-line"></i> Tableau de bord</h2>
    <p>Vue d'ensemble de votre flotte et des activités</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon">
            <i class="fas fa-clock"></i>
        </div>
        <div class="stat-info">
            <h3>@pendingRequests</h3>
            <p>Demandes en attente</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">
            <i class="fas fa-check-circle"></i>
        </div>
        <div class="stat-info">
            <h3>@supervisorApprovedRequests</h3>
            <p>Approuvées (Superviseur)</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">
            <i class="fas fa-flag-checkered"></i>
        </div>
        <div class="stat-info">
            <h3>@completedRequests</h3>
            <p>Voyages terminés</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">
            <i class="fas fa-car"></i>
        </div>
        <div class="stat-info">
            <h3>@activeVehicles</h3>
            <p>Véhicules disponibles</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">
            <i class="fas fa-users"></i>
        </div>
        <div class="stat-info">
            <h3>@totalDrivers</h3>
            <p>Chauffeurs GPS</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">
            <i class="fas fa-user-friends"></i>
        </div>
        <div class="stat-info">
            <h3>@totalUsers</h3>
            <p>Utilisateurs</p>
        </div>
    </div>
</div>

<div class="card">
    <h3 style="margin-bottom: 15px;">
        <i class="fas fa-history"></i> Demandes récentes
    </h3>

    @if (latestRequests != null && latestRequests.Any())
    {
    <div style="overflow-x: auto;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Employé</th>
                    <th>Départ</th>
                    <th>Destination</th>
                    <th>Date voyage</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in latestRequests)
                    {
                <tr>
                    <td>@request.Id</td>
                    <td>@request.EmployeeName</td>
                    <td>@request.Departure</td>
                    <td>@request.Destination</td>
                    <td>@request.TravelDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (request.Status == "Pending")
                                {
                        <span class="badge badge-warning">⏳ En attente</span>
                                }
                                else if (request.Status == "SupervisorApproved")
                                {
                        <span class="badge badge-info">✓ Approuvée (Sup.)</span>
                                }
                                else if (request.Status == "AdminApproved")
                                {
                        <span class="badge badge-success">✅ Approuvée (Admin)</span>
                                }
                                else if (request.Status == "Completed")
                                {
                        <span class="badge badge-success">🏁 Terminée</span>
                                }
                                else if (request.Status == "Rejected")
                                {
                        <span class="badge badge-danger">❌ Refusée</span>
                                }
                                else
                                {
                        <span class="badge badge-secondary">@request.Status</span>
                                }
                    </td>
                    <td>
                        <a href="/Admin/Requests" class="btn-sm btn-info">
                            <i class="fas fa-eye"></i> Voir
                        </a>
                    </td>
                </tr>
                    }
            </tbody>
        </table>
    </div>
    }
    else
    {
    <div style="text-align: center; padding: 40px; color: #7f8c8d;">
        <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 15px;"></i>
        <p>Aucune demande récente</p>
    </div>
    }
</div>

<div class="card">
    <h3 style="margin-bottom: 15px;">
        <i class="fas fa-chart-pie"></i> Statistiques rapides
    </h3>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
        <div style="text-align: center;">
            <div style="font-size: 36px; font-weight: bold; color: #00b4d8;">@pendingRequests</div>
            <div style="color: #7f8c8d;">Demandes en attente</div>
        </div>
        <div style="text-align: center;">
            <div style="font-size: 36px; font-weight: bold; color: #27ae60;">@completedRequests</div>
            <div style="color: #7f8c8d;">Voyages terminés</div>
        </div>
        <div style="text-align: center;">
            <div style="font-size: 36px; font-weight: bold; color: #f39c12;">@activeVehicles</div>
            <div style="color: #7f8c8d;">Véhicules disponibles</div>
        </div>
        <div style="text-align: center;">
            <div style="font-size: 36px; font-weight: bold; color: #9b59b6;">@totalUsers</div>
            <div style="color: #7f8c8d;">Utilisateurs actifs</div>
        </div>
    </div>
</div>

<style>
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table th,
        .data-table td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #e0e6ed;
        }

        .data-table th {
            background: #f8fafc;
            font-weight: 600;
            color: #4a5568;
        }

        .data-table tr:hover {
            background: #f8fafc;
        }

    .btn-sm {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 5px;
        text-decoration: none;
        font-size: 12px;
        transition: all 0.3s;
    }

    .btn-info {
        background: #e8f4f8;
        color: #00b4d8;
    }

        .btn-info:hover {
            background: #00b4d8;
            color: white;
        }

    .badge-secondary {
        background: #ecf0f1;
        color: #7f8c8d;
    }
</style>