@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Demandes";
    var requests = Model as List<GpsAdminServer.Models.TravelRequest>;
    var vehicles = ViewBag.Vehicles as List<GpsAdminServer.Models.Vehicle>;
}

<div class="page-header">
    <h2><i class="fas fa-tasks"></i> Gestion des demandes de voyage</h2>
    <p>Consultez et gérez toutes les demandes de voyage</p>
</div>

<div class="card">
    <div style="overflow-x: auto;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Employé</th>
                    <th>Départ</th>
                    <th>Destination</th>
                    <th>Date voyage</th>
                    <th>Heure arrivée</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (requests != null && requests.Any())
                {
                    foreach (var r in requests)
                    {
                <tr>
                    <td>@r.Id</td>
                    <td>@r.EmployeeName</td>
                    <td>@r.Departure</td>
                    <td>@r.Destination</td>
                    <td>@r.TravelDate.ToString("dd/MM/yyyy")</td>
                    <td>@r.ArrivalTime.ToString("HH:mm")</td>
                    <td>
                        @if (r.Status == "Pending")
                                {
                        <span class="badge badge-warning">⏳ En attente</span>
                                }
                                else if (r.Status == "SupervisorApproved")
                                {
                        <span class="badge badge-info">✓ Approuvée (Sup.)</span>
                                }
                                else if (r.Status == "AdminApproved")
                                {
                        <span class="badge badge-success">✅ Approuvée (Admin)</span>
                                }
                                else if (r.Status == "Completed")
                                {
                        <span class="badge badge-success">🏁 Terminée</span>
                                }
                                else if (r.Status == "Rejected")
                                {
                        <span class="badge badge-danger">❌ Refusée</span>
                                }
                                else
                                {
                        <span class="badge badge-secondary">@r.Status</span>
                                }
                    </td>
                    <td>
                        <a href="/Request/RequestDetails?id=@r.Id" class="btn-sm btn-info">
                            <i class="fas fa-eye"></i> Détails
                        </a>
                        @if (r.Status == "Pending")
                                {
                        <button class="btn-sm btn-success" onclick="openApproveModal(@r.Id)">
                            <i class="fas fa-check"></i> Approuver
                        </button>
                        <button class="btn-sm btn-danger" onclick="openRejectModal(@r.Id)">
                            <i class="fas fa-times"></i> Refuser
                        </button>
                                }
                        @if (r.Status == "AdminApproved" && r.Status != "Completed")
                                {
                        <form method="post" action="/Admin/CompleteRequest" style="display:inline;">
                            <input type="hidden" name="id" value="@r.Id" />
                            <button type="submit" class="btn-sm btn-primary">
                                <i class="fas fa-flag-checkered"></i> Terminer
                            </button>
                        </form>
                                }
                    </td>
                </tr>
                    }
                }
                else
                {
                <tr><td colspan="8" style="text-align:center;">Aucune demande</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Approbation -->
<div id="approveModal" class="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000;">
    <div class="modal-content" style="background:white; max-width:500px; margin:100px auto; padding:30px; border-radius:12px;">
        <span onclick="closeApproveModal()" style="float:right; cursor:pointer; font-size:24px;">&times;</span>
        <h3>Approuver la demande</h3>
        <div style="margin-bottom:15px;">
            <label>Commentaire (optionnel)</label>
            <textarea id="approveComments" class="form-control" rows="3"></textarea>
        </div>
        <div style="margin-bottom:15px;">
            <label>Véhicule à assigner</label>
            <select id="vehicleId" class="form-control">
                <option value="">-- Aucun --</option>
                @if (vehicles != null)
                {
                    foreach (var v in vehicles)
                    {
                <option value="@v.Id">@v.Brand @v.Model - @v.PlateNumber</option>
                    }
                }
            </select>
        </div>
        <button class="btn btn-success" onclick="confirmApprove()" style="width:100%;">Confirmer l'approbation</button>
    </div>
</div>

<!-- Modal Refus -->
<div id="rejectModal" class="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000;">
    <div class="modal-content" style="background:white; max-width:500px; margin:100px auto; padding:30px; border-radius:12px;">
        <span onclick="closeRejectModal()" style="float:right; cursor:pointer; font-size:24px;">&times;</span>
        <h3>Refuser la demande</h3>
        <div style="margin-bottom:15px;">
            <label>Raison du refus (obligatoire)</label>
            <textarea id="rejectComments" class="form-control" rows="3"></textarea>
        </div>
        <button class="btn btn-danger" onclick="confirmReject()" style="width:100%;">Confirmer le refus</button>
    </div>
</div>

<script>
    var currentRequestId = null;

    function openApproveModal(id) { currentRequestId = id; document.getElementById('approveModal').style.display = 'block'; }
    function closeApproveModal() { document.getElementById('approveModal').style.display = 'none'; document.getElementById('approveComments').value = ''; currentRequestId = null; }
    function openRejectModal(id) { currentRequestId = id; document.getElementById('rejectModal').style.display = 'block'; }
    function closeRejectModal() { document.getElementById('rejectModal').style.display = 'none'; document.getElementById('rejectComments').value = ''; currentRequestId = null; }

    function confirmApprove() {
        var comments = document.getElementById('approveComments').value;
        var vehicleId = document.getElementById('vehicleId').value;
        fetch(`/Admin/ApproveRequest?id=${currentRequestId}&comments=${encodeURIComponent(comments)}&vehicleId=${vehicleId}`, { method: 'POST' })
            .then(() => location.reload());
    }

    function confirmReject() {
        var comments = document.getElementById('rejectComments').value;
        if (!comments) { alert('Veuillez indiquer une raison'); return; }
        fetch(`/Admin/RejectRequest?id=${currentRequestId}&comments=${encodeURIComponent(comments)}`, { method: 'POST' })
            .then(() => location.reload());
    }

    window.onclick = function (e) {
        if (e.target == document.getElementById('approveModal')) closeApproveModal();
        if (e.target == document.getElementById('rejectModal')) closeRejectModal();
    }
</script>

<style>
    .form-control {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table th, .data-table td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #e0e6ed;
        }

        .data-table th {
            background: #f8fafc;
            font-weight: 600;
        }

    .btn-sm {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 5px;
        text-decoration: none;
        font-size: 12px;
        margin-right: 5px;
        border: none;
        cursor: pointer;
    }

    .btn-info {
        background: #e8f4f8;
        color: #00b4d8;
    }

    .btn-success {
        background: #e8f8f5;
        color: #27ae60;
    }

    .btn-primary {
        background: #e8f4f8;
        color: #00b4d8;
    }

    .btn-danger {
        background: #fdecea;
        color: #e74c3c;
    }
</style>