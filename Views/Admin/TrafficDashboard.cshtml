@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Trafic";
}

<div class="page-header">
    <h2><i class="fas fa-map-marked-alt"></i> Trafic des véhicules</h2>
    <p>Visualisez les trajets et déplacements de vos chauffeurs en temps réel</p>
</div>

<div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px;">
        <div>
            <label style="font-weight: 600;">📅 Sélectionner une date :</label>
            <input type="date" id="datePicker" style="margin-left: 10px; padding: 8px; border-radius: 8px; border: 1px solid #ddd;" />
        </div>
        <div>
            <button id="loadDataBtn" class="btn btn-primary" onclick="loadTrafficData()">
                <i class="fas fa-search"></i> Charger les données
            </button>
            <button class="btn btn-secondary" onclick="selectAllChauffeurs()" style="background:#7f8c8d;">
                <i class="fas fa-check-double"></i> Tous
            </button>
            <button class="btn btn-secondary" onclick="selectNoneChauffeurs()" style="background:#95a5a6;">
                <i class="fas fa-times"></i> Aucun
            </button>
        </div>
    </div>
</div>

<div class="card">
    <h3><i class="fas fa-users"></i> Filtrage par chauffeur</h3>
    <div id="chauffeurFilters" style="display: flex; flex-wrap: wrap; gap: 15px; margin-top: 10px;"></div>
</div>

<div id="map" style="height: 500px; width: 100%; border-radius: 12px; margin-bottom: 20px;"></div>

<div class="card" id="trafficStats" style="display: none;">
    <h3><i class="fas fa-chart-bar"></i> Résumé des trajets</h3>
    <div id="statsContent"></div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    var map = L.map('map').setView([36.8065, 10.1815], 12);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    var allTravels = [];
    var chauffeurColors = {};
    var polylines = [];
    var markers = [];
    var selectedChauffeurs = new Set();

    var colorPalette = ['#3498db', '#e74c3c', '#2ecc71', '#f39c12', '#9b59b6', '#1abc9c', '#e67e22', '#34495e', '#16a085', '#27ae60', '#2980b9', '#8e44ad'];

    async function loadTrafficData() {
        var date = document.getElementById('datePicker').value;
        if (!date) {
            alert('Veuillez sélectionner une date');
            return;
        }

        clearMap();

        try {
            var response = await fetch(`/Admin/GetTrafficData?date=${date}`);
            allTravels = await response.json();

            initChauffeurColors();
            buildFilters();
            displayStatistics(allTravels);
            updateMap();
        } catch (e) {
            console.error('Erreur:', e);
            alert('Erreur lors du chargement des données');
        }
    }

    function initChauffeurColors() {
        if (allTravels.travels && allTravels.travels.length > 0) {
            allTravels.travels.forEach((travel, idx) => {
                if (!chauffeurColors[travel.chauffeurId]) {
                    chauffeurColors[travel.chauffeurId] = colorPalette[idx % colorPalette.length];
                }
                if (selectedChauffeurs.size === 0) {
                    selectedChauffeurs.add(travel.chauffeurId);
                }
            });
        }
    }

    function buildFilters() {
        var container = document.getElementById('chauffeurFilters');
        if (!allTravels.travels || allTravels.travels.length === 0) {
            container.innerHTML = '<p>Aucun chauffeur trouvé pour cette date</p>';
            return;
        }

        var html = '';
        allTravels.travels.forEach(travel => {
            var color = chauffeurColors[travel.chauffeurId];
            var isChecked = selectedChauffeurs.has(travel.chauffeurId);
            html += `
                <div class="filter-item" onclick="toggleChauffeur('${travel.chauffeurId}')" style="cursor: pointer;">
                    <input type="checkbox" id="chk_${travel.chauffeurId}" ${isChecked ? 'checked' : ''} onclick="event.stopPropagation(); toggleChauffeur('${travel.chauffeurId}')" />
                    <span style="display: inline-block; width: 16px; height: 16px; background: ${color}; border-radius: 4px; margin: 0 5px;"></span>
                    <label for="chk_${travel.chauffeurId}" style="cursor: pointer;">${travel.nom}</label>
                    <span style="font-size: 11px; color: #666;"> (${travel.distanceKm} km)</span>
                </div>
            `;
        });
        container.innerHTML = html;
    }

    function toggleChauffeur(chauffeurId) {
        if (selectedChauffeurs.has(chauffeurId)) {
            selectedChauffeurs.delete(chauffeurId);
        } else {
            selectedChauffeurs.add(chauffeurId);
        }
        document.getElementById(`chk_${chauffeurId}`).checked = selectedChauffeurs.has(chauffeurId);
        updateMap();
        displayStatistics(allTravels);
    }

    function selectAllChauffeurs() {
        if (allTravels.travels) {
            allTravels.travels.forEach(travel => selectedChauffeurs.add(travel.chauffeurId));
            buildFilters();
            updateMap();
            displayStatistics(allTravels);
        }
    }

    function selectNoneChauffeurs() {
        selectedChauffeurs.clear();
        buildFilters();
        updateMap();
        displayStatistics(allTravels);
    }

    function clearMap() {
        polylines.forEach(line => map.removeLayer(line));
        markers.forEach(marker => map.removeLayer(marker));
        polylines = [];
        markers = [];
    }

    function updateMap() {
        clearMap();

        if (!allTravels.travels || allTravels.travels.length === 0) return;

        var filteredTravels = allTravels.travels.filter(t => selectedChauffeurs.has(t.chauffeurId));
        var bounds = L.latLngBounds();

        filteredTravels.forEach(travel => {
            var color = chauffeurColors[travel.chauffeurId];

            if (travel.trajectory && travel.trajectory.length >= 2) {
                var points = travel.trajectory.map(p => [p.latitude, p.longitude]);

                var polyline = L.polyline(points, {
                    color: color,
                    weight: 4,
                    opacity: 0.8
                }).addTo(map);

                polyline.bindPopup(`
                    <b>${travel.nom}</b><br/>
                    <span style="display:inline-block; width:12px; height:12px; background:${color}; border-radius:2px;"></span>
                    <b>Couleur:</b> ${color}<br/>
                    📏 Distance: ${travel.distanceKm} km<br/>
                    ⚡ Vitesse: ${travel.avgSpeed} km/h<br/>
                    🏁 Max: ${travel.maxSpeed} km/h
                `);

                polylines.push(polyline);

                var startIcon = L.divIcon({
                    html: `🚩 <span style="background:${color}; padding:2px 5px; border-radius:10px; font-size:10px;">${travel.nom}</span>`,
                    iconSize: [80, 25],
                    className: 'marker-icon'
                });

                var startMarker = L.marker([travel.trajectory[0].latitude, travel.trajectory[0].longitude], { icon: startIcon }).addTo(map);
                startMarker.bindPopup(`🚩 Début: ${formatTime(travel.startTime)}<br/>🚗 ${travel.nom}`);
                markers.push(startMarker);

                var endIcon = L.divIcon({
                    html: `🏁 <span style="background:${color}; padding:2px 5px; border-radius:10px; font-size:10px;">${travel.nom}</span>`,
                    iconSize: [80, 25],
                    className: 'marker-icon'
                });

                var endMarker = L.marker([travel.trajectory[travel.trajectory.length - 1].latitude, travel.trajectory[travel.trajectory.length - 1].longitude], { icon: endIcon }).addTo(map);
                endMarker.bindPopup(`🏁 Arrivée: ${formatTime(travel.endTime)}<br/>🚗 ${travel.nom}`);
                markers.push(endMarker);

                points.forEach(p => bounds.extend(p));
            }
        });

        if (filteredTravels.length > 0 && bounds.isValid()) {
            map.fitBounds(bounds, { padding: [30, 30] });
        }

        updateLegend(filteredTravels);
    }

    function updateLegend(filteredTravels) {
        var legendDiv = document.getElementById('legend');
        if (!legendDiv) {
            var legend = L.control({ position: 'bottomright' });
            legend.onAdd = function () {
                var div = L.DomUtil.create('div', 'info legend');
                div.id = 'legend';
                div.style.background = 'white';
                div.style.padding = '10px';
                div.style.borderRadius = '8px';
                div.style.boxShadow = '0 2px 10px rgba(0,0,0,0.2)';
                div.style.fontSize = '12px';
                div.style.maxWidth = '200px';
                return div;
            };
            legend.addTo(map);
        }

        var legendContainer = document.getElementById('legend');
        if (legendContainer && filteredTravels.length > 0) {
            var html = '<h4 style="margin:0 0 8px 0;">🎨 Légende</h4>';
            filteredTravels.forEach(travel => {
                var color = chauffeurColors[travel.chauffeurId];
                html += `<div style="display:flex; align-items:center; margin-bottom:5px;">
                            <span style="display:inline-block; width:20px; height:4px; background:${color}; margin-right:8px; border-radius:2px;"></span>
                            <span>${travel.nom}</span>
                        </div>`;
            });
            legendContainer.innerHTML = html;
        }
    }

    function displayStatistics(data) {
        var statsDiv = document.getElementById('trafficStats');
        var statsContent = document.getElementById('statsContent');

        if (data && data.travels && data.travels.length > 0) {
            var filteredTravels = data.travels.filter(t => selectedChauffeurs.has(t.chauffeurId));
            var totalDistance = filteredTravels.reduce((sum, t) => sum + t.distanceKm, 0);
            var avgSpeed = filteredTravels.length > 0 ? filteredTravels.reduce((sum, t) => sum + t.avgSpeed, 0) / filteredTravels.length : 0;

            statsDiv.style.display = 'block';
            statsContent.innerHTML = `
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-route"></i></div>
                        <div class="stat-info">
                            <h3>${filteredTravels.length}</h3>
                            <p>Trajets affichés</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-road"></i></div>
                        <div class="stat-info">
                            <h3>${totalDistance.toFixed(2)} km</h3>
                            <p>Distance totale</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-tachometer-alt"></i></div>
                        <div class="stat-info">
                            <h3>${avgSpeed.toFixed(1)} km/h</h3>
                            <p>Vitesse moyenne</p>
                        </div>
                    </div>
                </div>
                <div style="margin-top: 20px;">
                    <h4>Détail par chauffeur</h4>
                    <table style="width:100%; border-collapse:collapse;">
                        <thead>
                            <tr><th>Chauffeur</th><th>Couleur</th><th>Distance (km)</th><th>Vitesse moy.</th><th>Points</th></tr>
                        </thead>
                        <tbody>
                            ${filteredTravels.map(t => `
                                <tr>
                                    <td>${t.nom}</td>
                                    <td><span style="display:inline-block; width:20px; height:4px; background:${chauffeurColors[t.chauffeurId]}; border-radius:2px;"></span></td>
                                    <td>${t.distanceKm}</td>
                                    <td>${t.avgSpeed}</td>
                                    <td>${t.totalPoints}</td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
            `;
        } else {
            statsDiv.style.display = 'none';
        }
    }

    function formatTime(timeStr) {
        if (!timeStr) return "--";
        var d = new Date(timeStr);
        return d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    }

    document.getElementById('datePicker').valueAsDate = new Date();
</script>

<style>
    .filter-item {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        background: #f8fafc;
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .filter-item:hover {
            background: #e0e6ed;
        }

    .btn-secondary {
        background: #7f8c8d;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        cursor: pointer;
        margin-left: 8px;
    }

        .btn-secondary:hover {
            background: #6c7a7a;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin-bottom: 20px;
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 15px;
        background: #f8fafc;
        padding: 15px;
        border-radius: 12px;
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        background: #e8f4f8;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .stat-icon i {
            font-size: 24px;
            color: #00b4d8;
        }

    .stat-info h3 {
        font-size: 24px;
        margin: 0;
        color: #1a2a3a;
    }

    .stat-info p {
        margin: 0;
        color: #7f8c8d;
        font-size: 13px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 8px 12px;
        text-align: left;
        border-bottom: 1px solid #e0e6ed;
    }

    th {
        background: #f8fafc;
        font-weight: 600;
    }
</style>