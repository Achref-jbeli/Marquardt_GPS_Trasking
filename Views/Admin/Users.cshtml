@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Utilisateurs";
    var users = ViewBag.Users as List<GpsAdminServer.Models.ApplicationUser>;
    var currentUserId = ViewBag.CurrentUserId ?? 0;
}

<div class="page-header">
    <h2><i class="fas fa-users"></i> Gestion des utilisateurs</h2>
    <p>Ajoutez, modifiez ou supprimez les utilisateurs du système</p>
</div>

<div style="margin-bottom: 20px;">
    <a href="/Admin/AddUser" class="btn btn-primary">
        <i class="fas fa-plus"></i> Ajouter un utilisateur
    </a>
</div>

<div class="card">
    <div style="overflow-x: auto;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom complet</th>
                    <th>Nom d'utilisateur</th>
                    <th>Email</th>
                    <th>Département</th>
                    <th>Rôle</th>
                    <th>Superviseur</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (users != null && users.Any())
                {
                    foreach (var user in users)
                    {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.FullName</td>
                    <td>@user.Username</td>
                    <td>@user.Email ?? "-"</td>
                    <td>@user.Department ?? "-"</td>
                    <td>
                        @if (user.Role == "Admin")
                                {
                        <span class="badge badge-danger">👑 Admin</span>
                                }
                                else
                                {
                        <span class="badge badge-info">👤 Utilisateur</span>
                                }
                    </td>
                    <td>
                        @if (user.SupervisorId.HasValue)
                                {
                                    var sup = users.FirstOrDefault(u => u.Id == user.SupervisorId.Value);
                        @(sup?.FullName ?? "-")
                                }
                                else
                                {
                        <span>-</span>
                                }
                    </td>
                    <td>
                        @if (user.Id != currentUserId)
                                {
                        <a href="/Admin/EditUser?id=@user.Id" class="btn-sm btn-warning">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                        <form method="post" action="/Admin/DeleteUser" style="display:inline;" onsubmit="return confirm('Supprimer cet utilisateur ?')">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn-sm btn-danger" style="background:#e74c3c; color:white; border:none; padding:5px 10px; border-radius:5px;">
                                <i class="fas fa-trash"></i> Supprimer
                            </button>
                        </form>
                                }
                                else
                                {
                        <span style="color:#999;">(Compte actuel)</span>
                                }
                    </td>
                </tr>
                    }
                }
                else
                {
                <tr><td colspan="8" style="text-align:center;">Aucun utilisateur</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table th, .data-table td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #e0e6ed;
        }

        .data-table th {
            background: #f8fafc;
            font-weight: 600;
            color: #4a5568;
        }

    .btn-sm {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 5px;
        text-decoration: none;
        font-size: 12px;
        margin-right: 5px;
    }

    .btn-warning {
        background: #fef9e7;
        color: #f39c12;
    }

        .btn-warning:hover {
            background: #f39c12;
            color: white;
        }
</style>